import time
import random
import math
import re
import csv
import undetected_chromedriver as uc
from selenium.webdriver.common.by import By
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC

BASE_URL_P1 = "https://www.fotocasa.es/es/comprar/viviendas/majadahonda/todas-las-zonas/l"
BASE_URL_PAGES = "https://www.fotocasa.es/es/comprar/viviendas/majadahonda/todas-las-zonas/l/{}"

DELAY_MIN = 40
DELAY_MAX = 60
RESULTS_PER_PAGE = 30
MIN_PRICE = 50000
MAX_PRICE = 700000


def get_driver():
    options = uc.ChromeOptions()
    options.add_argument("--no-sandbox")
    options.add_argument("--disable-dev-shm-usage")
    options.add_argument("--window-size=1920,1080")
    options.add_argument("--lang=es-ES")
    options.add_argument(
        "--user-agent=Mozilla/5.0 (Windows NT 10.0; Win64; x64) "
        "AppleWebKit/537.36 (KHTML, like Gecko) "
        "Chrome/144.0.0.0 Safari/537.36"
    )
    driver = uc.Chrome(options=options, version_main=144, use_subprocess=True)
    return driver


def get_total_pages(driver):
    try:
        text = driver.find_element(By.XPATH, "//h1[@aria-live='polite']").text.strip()
        match = re.search(r'^(\d[\d\.]*)', text)
        if match:
            total = int(match.group(1).replace('.', ''))
            pages = math.ceil(total / RESULTS_PER_PAGE)
            print(f"Total inmuebles: {total} → {pages} páginas")
            return pages
        return 1
    except Exception as e:
        print(f"  ⚠️ No se pudo leer total de páginas: {e}")
        return 1


def wait_for_page_load(driver, timeout=90):
    WebDriverWait(driver, timeout).until(
        lambda d: d.execute_script("return document.readyState") == "complete"
    )
    time.sleep(4)

    # Scroll muy lento para que React hidrate cada skeleton antes de continuar
    scroll_step = 100
    scroll_pause = 3  # más lento que antes
    page_height = driver.execute_script("return document.body.scrollHeight")
    current_pos = 0

    while current_pos < page_height:
        current_pos += scroll_step
        driver.execute_script(f"window.scrollTo(0, {current_pos});")
        time.sleep(scroll_pause)
        page_height = driver.execute_script("return document.body.scrollHeight")

    driver.execute_script("window.scrollTo(0, 0);")
    time.sleep(2)

    # Esperar a que NO queden skeletons: todos los articles deben tener enlace
    print("  [debug] Esperando hidratación completa de skeletons...")
    try:
        WebDriverWait(driver, 30).until(
            lambda d: d.execute_script("""
                var arts = document.querySelectorAll('section.re-SearchResult article');
                var total = arts.length;
                if (total === 0) return false;
                var conEnlace = [...arts].filter(
                    a => a.querySelector('a[href*="/comprar/vivienda/"]')
                ).length;
                return conEnlace >= Math.min(total, 25);
            """)
        )
    except:
        pass  # Si timeout, intentamos extraer lo que haya

    n_total = driver.execute_script(
        "return document.querySelectorAll('section.re-SearchResult article').length"
    )
    n_con_enlace = driver.execute_script("""
        return [...document.querySelectorAll('section.re-SearchResult article')]
            .filter(a => a.querySelector('a[href*="/comprar/vivienda/"]')).length
    """)
    print(f"  [debug] articles total: {n_total} | con enlace (hidratados): {n_con_enlace}")


def extract_properties_fotocasa(driver):
    """
    Extrae propiedades usando JavaScript para obtener los articles,
    y Selenium para leer los datos de cada uno.
    El selector usa 'section.re-SearchResult article' via JS/XPath
    porque la clase '@container' no es válida en CSS selector de Selenium.
    """
    properties = []
    seen_urls = set()

    # Obtener articles via XPath (no depende de clases con @)
    cards = driver.find_elements(
        By.XPATH,
        "//section[contains(@class,'re-SearchResult')]//article"
    )
    print(f"  → Cards encontradas: {len(cards)}")

    for card in cards:
        prop = {}

        # URL e ID
        try:
            links = card.find_elements(
                By.XPATH, ".//a[contains(@href,'/comprar/vivienda/')]"
            )
            if not links:
                continue
            href = links[0].get_attribute('href')
            prop['url'] = href.split('?')[0] if href else "N/A"
        except:
            continue

        if prop['url'] == "N/A" or prop['url'] in seen_urls:
            continue
        seen_urls.add(prop['url'])

        id_match = re.search(r'(\d+)d?/?$', prop['url'].rstrip('/'))
        prop['id'] = id_match.group(1) if id_match else "N/A"

        # Título
        try:
            prop['title'] = card.find_element(By.XPATH, ".//h3//a").text.strip()
        except:
            prop['title'] = "N/A"

        # Zona
        try:
            # p con opacity-75 y truncate es la zona
            prop['zone'] = card.find_element(
                By.XPATH,
                ".//p[contains(@class,'truncate') and contains(@class,'text-on-surface')]"
            ).text.strip()
        except:
            prop['zone'] = "N/A"

        # Precio — span dentro del div con text-display-3
        try:
            prop['price'] = card.find_element(
                By.XPATH,
                ".//div[contains(@class,'text-display-3')]//span[1]"
            ).text.strip()
        except:
            prop['price'] = "N/A"

        # Características
        prop['rooms'] = "N/A"
        prop['bathrooms'] = "N/A"
        prop['size'] = "N/A"
        prop['floor'] = "N/A"
        prop['features'] = "N/A"
        try:
            items = card.find_elements(
                By.XPATH,
                ".//ul[contains(@class,'text-body-1')]//li"
            )
            extras = []
            for item in items:
                text = item.text.strip()
                if not text:
                    continue
                tl = text.lower()
                if 'hab' in tl:
                    prop['rooms'] = text
                elif 'baño' in tl:
                    prop['bathrooms'] = text
                elif 'm²' in text or re.search(r'\d+ m', text):
                    prop['size'] = text
                elif any(p in tl for p in ['planta', 'bajo', 'ático', 'atico', 'sótano', 'semisótano']):
                    prop['floor'] = text
                else:
                    extras.append(text)
            if extras:
                prop['features'] = ', '.join(extras)
        except:
            pass

        # Descripción
        try:
            prop['description'] = card.find_element(
                By.XPATH,
                ".//p[contains(@class,'text-body-2') and contains(@class,'line-clamp')]"
            ).text.strip()
        except:
            prop['description'] = "N/A"

        # Fotos
        try:
            photos_elem = card.find_element(
                By.XPATH,
                ".//a[contains(@href,'multimedia=image') and contains(@href,'isGalleryOpen=true')]"
            )
            m = re.search(r'\d+', photos_elem.text.strip())
            prop['photos'] = int(m.group()) if m else 0
        except:
            prop['photos'] = 0

        properties.append(prop)

    return properties


def parse_price(price_str):
    try:
        return int(re.sub(r'[^\d]', '', price_str))
    except:
        return None


def filter_properties(properties, min_price=MIN_PRICE, max_price=MAX_PRICE):
    filtered = []
    excluded = 0
    seen_ids = set()

    for p in properties:
        if p.get('title') == "N/A" or p.get('price') == "N/A":
            excluded += 1
            continue
        if not p.get('id') or p['id'] in seen_ids:
            excluded += 1
            continue
        price_value = parse_price(p['price'])
        if price_value is None or price_value < min_price or price_value > max_price:
            excluded += 1
            continue
        seen_ids.add(p['id'])
        p['price_value'] = price_value
        filtered.append(p)

    print(f"  → Válidas: {len(filtered)} | Excluidas: {excluded}")
    return filtered


def scrape_page(driver, page_label):
    for attempt in range(1, 4):
        try:
            wait_for_page_load(driver)
        except Exception as e:
            print(f"  ⚠️ Error en wait (intento {attempt}): {e}")
            if attempt < 3:
                print("  ↺ Recargando en 20s...")
                time.sleep(20)
                driver.refresh()
            continue

        props = extract_properties_fotocasa(driver)

        if len(props) == 0 and attempt < 3:
            print(f"  ⚠️ 0 cards en intento {attempt}, recargando en 20s...")
            time.sleep(20)
            driver.refresh()
            continue

        print(f"  → {len(props)} propiedades extraídas en página {page_label}")
        return props

    print(f"  ✗ Página {page_label} falló tras 3 intentos.")
    return []


def main():
    driver = get_driver()
    all_properties = []

    try:
        print(f"Navegando a {BASE_URL_P1}...")
        driver.get(BASE_URL_P1)

        print("\n⚠️  Resuelve el captcha si aparece.")
        print("⚠️  Espera a que veas las tarjetas de viviendas en pantalla.")
        input("Pulsa ENTER cuando veas el listado... ")

        print("\nScrapeando página 1...")
        props = scrape_page(driver, "1")
        all_properties.extend(props)

        total_pages = get_total_pages(driver)
        print(f"Total páginas: {total_pages}\n")

        for page_num in range(2, total_pages + 1):
            delay = random.uniform(DELAY_MIN, DELAY_MAX)
            print(f"Esperando {delay:.1f}s antes de página {page_num}...")
            time.sleep(delay)

            url = BASE_URL_PAGES.format(page_num)
            print(f"Scrapeando página {page_num}: {url}")
            driver.get(url)

            props = scrape_page(driver, str(page_num))
            all_properties.extend(props)

        print("\nAplicando filtros...")
        all_properties = filter_properties(all_properties)

        print("\n" + "=" * 60)
        print("VIVIENDAS EN VENTA — MAJADAHONDA (fotocasa.es)")
        print(f"Precio entre {MIN_PRICE:,}€ y {MAX_PRICE:,}€")
        print("=" * 60 + "\n")

        for i, p in enumerate(all_properties, 1):
            print(f"[{i}] ID: {p['id']} | {p['title']}")
            print(f"     Zona    : {p['zone']}")
            print(f"     Precio  : {p['price']}")
            print(f"     Hab.    : {p['rooms']}")
            print(f"     Baños   : {p['bathrooms']}")
            print(f"     Tamaño  : {p['size']}")
            print(f"     Planta  : {p['floor']}")
            print(f"     Extras  : {p['features']}")
            print(f"     Fotos   : {p['photos']}")
            print(f"     URL     : {p['url']}")
            desc = p['description']
            print(f"     Desc.   : {desc[:120]}{'...' if len(desc) > 120 else ''}")
            print()

        print("=" * 60)
        print(f"Total propiedades: {len(all_properties)}")

        fieldnames = [
            "id", "title", "zone", "price", "price_value",
            "rooms", "bathrooms", "size", "floor", "features",
            "photos", "url", "description"
        ]
        with open("fotocasa_majadahonda.csv", "w", newline="", encoding="utf-8") as f:
            writer = csv.DictWriter(f, fieldnames=fieldnames)
            writer.writeheader()
            for p in all_properties:
                writer.writerow({k: p.get(k, "N/A") for k in fieldnames})

        print("\n✅ Datos guardados en fotocasa_majadahonda.csv")
        input("\nPulsa ENTER para cerrar el navegador... ")

    finally:
        try:
            driver.service.stop()
        except Exception:
            pass
        try:
            driver.keep_alive = False
            driver.quit()
        except OSError:
            pass
        except Exception:
            pass


if __name__ == "__main__":
    main()
